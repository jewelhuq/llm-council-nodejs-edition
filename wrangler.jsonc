{
    "name": "llm-council",
    "main": "src/index.js",
    "compatibility_date": "2026-05-03",
    "assets": {
        "directory": "public",
        "binding": "ASSETS",
        "run_worker_first": ["/api/*"]
    },
    "d1_databases": [
        {
            "binding": "DB",
            "database_name": "llm-council",
            "database_id": ""
        }
    ]
    // Secrets (set with `wrangler secret put <NAME>`, or .dev.vars for local dev):
    //   ENCRYPTION_KEY - random string used to encrypt stored OpenRouter API keys
}
